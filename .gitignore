# Ignore everything by default, then allow only repository-owned paths.
*

# Repository configuration
!/.gitignore
!/pyproject.toml
!/.github/
!/.github/**

# Root documentation and project metadata
!/ATTRIBUTIONS.md
!/CHANGELOG.md
!/CODE_OF_CONDUCT.md
!/CONTRIBUTING.md
!/GOVERNANCE.md
!/LICENSE
!/README.md
!/SECURITY.md
!/SUPPORT.md

# Source, tests, examples, scripts, and docs
!/docs/
!/docs/**
!/examples/
!/examples/**
!/scripts/
!/scripts/**
!/src/
!/src/**
!/tests/
!/tests/**

# Generated Python/cache/build artifacts inside allowed directories
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
.coverage
htmlcov/
.mypy_cache/
.pytest_cache/
.ruff_cache/
dist/
build/
